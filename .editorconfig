root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx,vb,vbx}]
indent_size = 4
charset = utf-8-bom

# Remove unused usings
dotnet_diagnostic.IDE0005.severity = warning
dotnet_style_remove_unnecessary_suppressions = true:warning
csharp_style_namespace_declarations = file_scoped:suggestion

[*.{json,yml,yaml,html,css,js,md}]
indent_size = 2

[*.{xml,csproj,props,targets}]
indent_size = 2
